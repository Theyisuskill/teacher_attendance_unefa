<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="res.groups.privilege" id="res_groups_privilege_teacher_attendance">
        <field name="name">Teacher Attendance</field>
        <field name="sequence">50</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
    </record>

    <record id="group_teacher" model="res.groups">
        <field name="name">Teacher</field>
        <field name="privilege_id" ref="res_groups_privilege_teacher_attendance"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="sequence">10</field>
    </record>

    <record id="group_coordinator" model="res.groups">
        <field name="name">Coordinator</field>
        <field name="privilege_id" ref="res_groups_privilege_teacher_attendance"/>
        <field name="implied_ids" eval="[(4, ref('group_teacher'))]"/>
        <field name="sequence">20</field>
    </record>
</odoo>
