<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_attendance" model="ir.ui.view">
        <field name="name">res.users.form.inherit.attendance</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Attendance" name="attendance">
                    <group>
                        <group string="Kiosk Mode">
                            <field name="attendance_pin" password="True" placeholder="4-digit PIN"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
