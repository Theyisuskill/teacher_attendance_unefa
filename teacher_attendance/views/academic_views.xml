<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Subjects -->
    <record id="view_subject_list" model="ir.ui.view">
        <field name="name">attendance.subject.list</field>
        <field name="model">attendance.subject</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <record id="action_attendance_subject" model="ir.actions.act_window">
        <field name="name">Subjects</field>
        <field name="res_model">attendance.subject</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Substitutions -->
    <record id="view_substitution_form" model="ir.ui.view">
        <field name="name">attendance.substitution.form</field>
        <field name="model">attendance.substitution</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" string="Activate" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_done" string="Mark Done" type="object" invisible="state != 'active'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="classroom_id"/>
                            <field name="subject_id"/>
                        </group>
                        <group>
                            <field name="original_teacher_id"/>
                            <field name="substitute_teacher_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_substitution_list" model="ir.ui.view">
        <field name="name">attendance.substitution.list</field>
        <field name="model">attendance.substitution</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="classroom_id"/>
                <field name="subject_id"/>
                <field name="substitute_teacher_id"/>
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-info="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="action_attendance_substitution" model="ir.actions.act_window">
        <field name="name">Substitutions</field>
        <field name="res_model">attendance.substitution</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
