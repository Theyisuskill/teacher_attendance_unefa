<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_attendance_log" model="ir.actions.report">
        <field name="name">Attendance Report</field>
        <field name="model">attendance.log</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">teacher_attendance.report_attendance_log_template</field>
        <field name="report_file">teacher_attendance.report_attendance_log_template</field>
        <field name="print_report_name">'Attendance_%s' % (object.teacher_id.name)</field>
        <field name="binding_model_id" ref="model_attendance_log"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_attendance_log_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure"/>
                        <h2>Attendance Certificate</h2>
                        <div class="row mt32 mb32">
                            <div class="col-auto mw-100 mb-2">
                                <strong>Teacher:</strong>
                                <p class="m-0" t-field="o.teacher_id"/>
                            </div>
                            <div class="col-auto mw-100 mb-2">
                                <strong>Classroom:</strong>
                                <p class="m-0" t-field="o.classroom_id"/>
                            </div>
                            <div class="col-auto mw-100 mb-2">
                                <strong>Check-in:</strong>
                                <p class="m-0" t-field="o.check_in"/>
                            </div>
                        </div>

                        <table class="table table-sm o_main_table mt48">
                            <thead>
                                <tr>
                                    <th>Field</th>
                                    <th>Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Status</td>
                                    <td><span t-field="o.status"/></td>
                                </tr>
                                <tr>
                                    <td>GPS Distance</td>
                                    <td><span t-field="o.distance"/> meters</td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="mt-5 text-center border-top pt-3" style="width: 200px; margin: 0 auto;">
                            <p>Authorized Signature</p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
